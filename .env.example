# ── LLM API Keys ───────────────────────────────────────────────────────────────
# OpenAI API Key (Required for OpenAI models)
OPENAI_API_KEY=sk-your-openai-key-here

# DeepSeek API Key (Optional, for DeepSeek models)
DEEPSEEK_API_KEY=your-deepseek-key-here

# Google API Key (Optional, for Gemini models)
GOOGLE_API_KEY=your-google-key-here

# Anthropic API Key (Optional, for Claude models)
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── Security ────────────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed in production (generate with: openssl rand -hex 32)
SECRET_KEY=REPLACE_ME_WITH_A_STRONG_RANDOM_SECRET

# ── FastAPI / Streamlit ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Database ────────────────────────────────────────────────────────────────────
DB_PATH=data/db/rag.db

# ── Neo4j Graph Store ───────────────────────────────────────────────────────────
# Used by both FastAPI and Streamlit containers
GRAPH_STORE_URI=bolt://localhost:7687
GRAPH_STORE_USER=neo4j
# MUST be changed from the default — set in your shell or .env before running Docker
GRAPH_STORE_PASSWORD=your-neo4j-password-here
